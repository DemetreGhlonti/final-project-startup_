# many to many relation
class Author:
    def __init__(self, name):
        self.name = name
        self.books = []

    def add_book(self, book):
        self.books.append(book)


class Book:
    def __init__(self, title):
        self.title = title
        self.authors = []

    def add_author(self, author):
        self.authors.append(author)


author1 = Author("გიორგი")
author2 = Author("ნინო")

book1 = Book("Python საფუძვლები")
book2 = Book("OOP პროგრამირება")

author1.add_book(book1)
author1.add_book(book2)

author2.add_book(book2)

book1.add_author(author1)

book2.add_author(author1)
book2.add_author(author2)

for book in [book1, book2]:
    print(f"\nწიგნი: {book.title}")
    print("ავტორები:")

    for author in book.authors:
        print(author.name)

class Animal:
    def __init__(self, name):
        self.name = name

    def speak(self):
        print("ცხოველი გამოსცემს ხმას")


# simple inheritence OOP code
class Dog(Animal):

    def speak(self):
        print(f"{self.name} ყეფს")


dog1 = Dog("ბობი")

dog1.speak()


# abstraction
from abc import ABC, abstractmethod


class Vehicle(ABC):

    @abstractmethod
    def move(self):
        pass


class Car(Vehicle):

    def move(self):
        print("მანქანა მოძრაობს")


car1 = Car()
car1.move()


